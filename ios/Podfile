# flutter_nearby_connections_plus v1.2.2 ships its iOS podspec named
# 'flutter_nearby_connections.podspec' but CocoaPods ≥1.11 requires the
# filename to match the pub package name. Also patch the ObjC bridging header
# import so it references the renamed module.
require 'fileutils'
_plus_ios = File.join(__dir__, '.symlinks', 'plugins',
                       'flutter_nearby_connections_plus', 'ios')
if File.directory?(_plus_ios)
  _src = File.join(_plus_ios, 'flutter_nearby_connections.podspec')
  _dst = File.join(_plus_ios, 'flutter_nearby_connections_plus.podspec')
  if File.exist?(_src) && !File.exist?(_dst)
    File.write(_dst, File.read(_src)
      .sub("s.name             = 'flutter_nearby_connections'",
           "s.name             = 'flutter_nearby_connections_plus'"))
  end
  _m = File.join(_plus_ios, 'Classes', 'FlutterNearbyConnectionsPlugin.m')
  if File.exist?(_m)
    content = File.read(_m)
    patched = content
      .gsub('flutter_nearby_connections/flutter_nearby_connections-Swift.h',
            'flutter_nearby_connections_plus/flutter_nearby_connections_plus-Swift.h')
      .gsub('"flutter_nearby_connections-Swift.h"',
            '"flutter_nearby_connections_plus-Swift.h"')
    File.write(_m, patched) if patched != content
  end
end

# Uncomment this line to define a global platform for your project
# platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end
end
